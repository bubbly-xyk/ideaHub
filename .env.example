# PostgreSQL connection string
# Local example:  postgresql://postgres:password@localhost:5432/ideahub
# Supabase example: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres
# Neon example: postgresql://[user]:[password]@[endpoint].neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/ideahub
